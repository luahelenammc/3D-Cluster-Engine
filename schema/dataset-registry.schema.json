{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://luahelenammc.github.io/3D-Cluster-Engine/schema/dataset-registry.schema.json",
  "title": "LMS 3D Cluster Engine Dataset Registry",
  "description": "Registry of canonical datasets published by the LMS 3D Cluster Engine.",
  "type": "object",
  "additionalProperties": false,
  "required": ["registryVersion", "datasets"],
  "properties": {
    "registryVersion": {
      "const": "1.0"
    },
    "defaultDataset": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "path"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?![A-Za-z][A-Za-z0-9+.-]*:)[A-Za-z0-9._/-]+\\.json$"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "featured": {
          "type": "boolean"
        }
      }
    }
  }
}
